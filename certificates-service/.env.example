# =============================================================================
# СертификатБаза — Конфигурация окружения
# Скопируйте этот файл в .env и заполните реальными значениями
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# База данных PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=certuser
POSTGRES_PASSWORD=certpass123
POSTGRES_DB=certificates_db

DATABASE_URL=postgresql+asyncpg://certuser:certpass123@postgres:5432/certificates_db
DATABASE_URL_SYNC=postgresql+psycopg2://certuser:certpass123@postgres:5432/certificates_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Celery брокер и бэкенд используют отдельные базы Redis (1 и 2)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# Безопасность
# ОБЯЗАТЕЛЬНО смените SECRET_KEY перед деплоем в продакшн!
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-here-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# Загрузка файлов
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=52428800

# -----------------------------------------------------------------------------
# Приложение
# -----------------------------------------------------------------------------
DEBUG=false
ENVIRONMENT=production

# Список допустимых источников CORS (через запятую)
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80
